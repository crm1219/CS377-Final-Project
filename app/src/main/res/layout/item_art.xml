<?xml version="1.0" encoding="utf-8"?>

<!--
    this layout represents one artwork item in the RecyclerView,
    shows: the artwork image, the artwork title, artist, and date
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- thumbnail image from the Art Institute of Chicago API -->
        <ImageView
            android:id="@+id/ivArtwork"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:contentDescription="Artwork image"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- artwork title -->
            <TextView
                android:id="@+id/tvArtworkTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- artist -->
            <TextView
                android:id="@+id/tvArtistName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />

            <!-- artwork date -->
            <TextView
                android:id="@+id/tvArtworkDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>